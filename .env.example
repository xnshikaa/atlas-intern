# =============================================================================
# Atlas AI Command Center - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values.
# DO NOT commit .env to version control.
# For local Docker: copy to .env and run docker compose up; many defaults work.
# For production: set SECRET_KEY, NEXTAUTH_SECRET, and Keycloak/DB credentials.

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================

# --- Application ---
APP_ENV=development  # development or production
APP_NAME=Atlas AI Command Center
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
DEBUG=false

# --- CORS (comma-separated; default allows localhost:3000,3000) ---
# CORS_ORIGINS=http://localhost:3000,https://your-app.example.com

# --- Database (PostgreSQL 15) ---
DATABASE_URL=postgresql+asyncpg://atlas:atlas_secret@db:5432/atlas_db

# --- JWT (generate with: openssl rand -base64 32) ---
SECRET_KEY=change-me-in-production-use-openssl-rand-base64-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Storage ---
STORAGE_BACKEND=local  # local or gcs
# GCS_BUCKET_NAME=your-bucket-name  # Only needed if STORAGE_BACKEND=gcs

# --- AI Features (Gemini) ---
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=  # Optional but required for AI features
AI_MODEL=gemini-2.0-flash-exp  # or gemini-1.5-pro, gemini-1.5-flash

# --- User Registration ---
APPROVED_EMAIL_DOMAINS=atlasuniversity.edu.in,example.com  # Comma-separated domains for auto-approval

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# --- Next.js ---
NODE_ENV=development  # development or production
FRONTEND_TARGET=dev  # dev (hot reload) or prod (optimized build)

# --- API URLs ---
NEXT_PUBLIC_API_URL=http://localhost:8000  # Backend API URL (browser-side)
NEXT_PUBLIC_BASE_PATH=  # Base path for reverse proxy (leave empty for local)

# =============================================================================
# KEYCLOAK CONFIGURATION
# =============================================================================

# --- Keycloak Server (Backend needs these) ---
KEYCLOAK_SERVER_URL=https://your-keycloak-instance.run.app  # Your Keycloak URL
KEYCLOAK_REALM=atlas
KEYCLOAK_CLIENT_ID=atlas-backend
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# --- Keycloak Admin API (for user management) ---
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=your-admin-client-secret

# --- Keycloak Database ---
KEYCLOAK_DB_VENDOR=postgres
KEYCLOAK_DB_ADDR=db
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_DATABASE=keycloak_db
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_secret

# --- Keycloak Admin User (Initial setup only) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_password_change_me

# =============================================================================
# DOCKER & DEVELOPMENT
# =============================================================================

# --- Port Mapping (change if ports are in use) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
DB_PORT=5432
KEYCLOAK_PORT=8080

# --- PostgreSQL ---
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_secret
POSTGRES_DB=atlas_db
