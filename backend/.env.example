# Atlas AI Command Center - Environment Template
# Copy to .env and fill in values

# Database (PostgreSQL 15) - use atlas_db for docker-compose
DATABASE_URL=postgresql+asyncpg://atlas:atlas_secret@localhost:5432/atlas_db

# JWT (generate a long random string for production)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_NAME=Atlas AI Command Center
DEBUG=false
